# Runtime secrets (used by the bot on the server).
TELEGRAM_BOT_TOKEN=

# Local deploy-only settings (not used by the running app).
# Optional: server SSH/sudo password for scripts/deploy.sh and scripts/service-debian.sh.
# Requires sshpass locally: brew install hudochenkov/sshpass/sshpass
# When unset, deploy prompts for passwords interactively.
DEPLOY_PASSWORD=
